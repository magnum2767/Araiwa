function buildChulaGrid(containerId, foods) {
  var el = document.getElementById(containerId);
  var html = '';
  for (var i = 0; i < foods.length; i++) {
    var f = foods[i];
    html += '<div class="chula-card">';
    if (f.img) {
      html += '<img class="chula-img" src="' + f.img + '" alt="' + f.nm + '" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">';
      html += '<div class="chula-emo" style="background:' + f.bg + ';display:none">' + f.emo + '</div>';
    } else {
      html += '<div class="chula-emo" style="background:' + f.bg + '">' + f.emo + '</div>';
    }
    html += '<div class="chula-info">';
    html += '<div class="chula-nm">' + f.nm + '</div>';
    html += '<div class="chula-cal">' + f.c + ' <small>kcal</small></div>';
    html += '<div class="chula-note">' + f.note + '</div>';
    if (f.h) html += '<span class="healthy-tag">✅ เมนูสุขภาพ</span>';
    html += '</div></div>';
  }
  el.innerHTML = html;
}

