<!DOCTYPE html>

<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TU WISH FLAVOUR – มื้อนี้กี่แคลอรี่?</title>
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600;700&family=Prompt:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--orange:#FF6B35;--yellow:#FFD166;--green:#06D6A0;--red:#EF233C;--blue:#4361EE;--dark:#1a1a2e;--bg:#f7f3ee;--text:#222;--sub:#888;--border:#e8e0d5;--shadow:0 4px 24px rgba(0,0,0,.10)}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Sarabun',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
.topbar{background:var(--dark);color:#fff;text-align:center;padding:8px;font-family:'Prompt',sans-serif;font-size:12px;letter-spacing:1.5px;font-weight:600}
header{background:#fff;border-bottom:2px solid var(--border);padding:0 16px;display:flex;align-items:center;justify-content:space-between;height:60px;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,.06)}
.logo{font-family:'Prompt',sans-serif;font-size:19px;font-weight:800;color:var(--dark);white-space:nowrap}
.logo span{color:var(--orange)}
.nav-tabs{display:flex;gap:2px;background:#f0ebe4;border-radius:12px;padding:4px;overflow-x:auto;scrollbar-width:none}
.nav-tabs::-webkit-scrollbar{display:none}
.nav-tab{padding:6px 11px;border-radius:9px;border:none;background:transparent;cursor:pointer;font-family:'Sarabun',sans-serif;font-size:12px;font-weight:600;color:var(--sub);transition:all .2s;white-space:nowrap}
.nav-tab.active{background:#fff;color:var(--orange);box-shadow:0 2px 8px rgba(0,0,0,.08)}
.nav-tab:hover:not(.active){background:rgba(255,255,255,.6);color:var(--text)}
.page{display:none}.page.active{display:block}

/* HERO */
.hero{background:linear-gradient(135deg,var(–dark) 0%,#16213e 60%,#0f3460 100%);padding:60px 24px 72px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:’’;position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(255,107,53,.15) 0%,transparent 70%);top:-100px;left:50%;transform:translateX(-50%)}
.hero-label{display:inline-block;background:rgba(255,107,53,.2);color:var(–orange);border:1px solid rgba(255,107,53,.4);border-radius:20px;padding:6px 18px;font-size:12px;font-weight:600;letter-spacing:1px;margin-bottom:18px}
.hero h1{font-family:‘Prompt’,sans-serif;font-size:clamp(28px,5vw,50px);font-weight:800;color:#fff;line-height:1.15;margin-bottom:14px}
.hero h1 em{color:var(–yellow);font-style:normal}
.hero p{color:rgba(255,255,255,.65);font-size:15px;max-width:480px;margin:0 auto 28px;line-height:1.7}
.hero-cta{display:inline-flex;gap:12px;flex-wrap:wrap;justify-content:center}
.btn-p{background:var(–orange);color:#fff;border:none;padding:13px 26px;border-radius:12px;font-family:‘Sarabun’,sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:all .2s;box-shadow:0 4px 16px rgba(255,107,53,.4)}
.btn-p:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(255,107,53,.5)}
.btn-s{background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.2);padding:13px 22px;border-radius:12px;font-family:‘Sarabun’,sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all .2s}
.btn-s:hover{background:rgba(255,255,255,.2)}
.stats-row{display:flex;gap:14px;justify-content:center;margin-top:44px;flex-wrap:wrap}
.stat-card{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:16px 24px;text-align:center;backdrop-filter:blur(8px);min-width:90px}
.stat-card .num{font-family:‘Prompt’,sans-serif;font-size:24px;font-weight:800;color:var(–yellow)}
.stat-card .lbl{color:rgba(255,255,255,.5);font-size:10px;margin-top:3px}

/* SECTION / CARDS */
.section{max-width:1100px;margin:0 auto;padding:44px 24px}
.sec-title{font-family:‘Prompt’,sans-serif;font-size:22px;font-weight:700;margin-bottom:8px}
.sec-title em{color:var(–orange);font-style:normal}
.sec-sub{color:var(–sub);font-size:13px;margin-bottom:28px}
.card{background:#fff;border-radius:18px;padding:24px;box-shadow:var(–shadow);margin-bottom:20px}
.card h3{font-family:‘Prompt’,sans-serif;font-size:17px;font-weight:700;margin-bottom:6px}
.card .csub{color:var(–sub);font-size:12px;margin-bottom:16px}

/* CANTEEN GRID */
.canteen-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:18px}
.canteen-card{background:#fff;border-radius:20px;overflow:hidden;box-shadow:var(–shadow);cursor:pointer;transition:all .25s;border:2px solid transparent}
.canteen-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.15)}
.c-thumb{width:100%;height:150px;display:flex;align-items:center;justify-content:center;font-size:56px;background:linear-gradient(135deg,#f7ede2,#fde8d8)}
.c-info{padding:18px}
.c-badge{display:inline-block;background:var(–yellow);color:var(–dark);font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;margin-bottom:7px}
.c-name{font-family:‘Prompt’,sans-serif;font-size:16px;font-weight:700;margin-bottom:4px}
.c-desc{color:var(–sub);font-size:12px;line-height:1.6}
.c-meta{display:flex;gap:14px;margin-top:12px;padding-top:12px;border-top:1px solid var(–border);font-size:12px;color:var(–sub)}
.c-meta strong{color:var(–text);font-weight:700}

/* FOOD CALC */
.calc-layout{display:grid;grid-template-columns:1fr 350px;gap:22px;max-width:1100px;margin:0 auto;padding:28px 24px;align-items:start}
@media(max-width:820px){.calc-layout{grid-template-columns:1fr}}
.food-sec-hd{font-family:‘Prompt’,sans-serif;font-size:12px;font-weight:700;color:var(–sub);letter-spacing:.5px;margin:18px 0 10px;padding-bottom:6px;border-bottom:2px solid var(–border);text-transform:uppercase}
.food-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(138px,1fr));gap:10px}
.food-card{background:#fff;border-radius:14px;overflow:hidden;cursor:pointer;transition:all .2s;border:2.5px solid transparent;box-shadow:0 2px 10px rgba(0,0,0,.06);position:relative}
.food-card:hover{transform:translateY(-3px);box-shadow:0 8px 22px rgba(0,0,0,.12)}
.food-card.sel{border-color:var(–green);background:#f0fff9}
.food-card.sel::after{content:‘✓’;position:absolute;top:7px;right:7px;background:var(–green);color:#fff;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700}
.food-img{width:100%;height:100px;object-fit:cover;display:block}
.food-emo{width:100%;height:100px;display:flex;align-items:center;justify-content:center;font-size:44px;background:linear-gradient(135deg,#fef3ec,#fff3e0)}
.food-info{padding:9px}
.food-nm{font-weight:700;font-size:11px;line-height:1.4;margin-bottom:3px}
.food-cal{font-family:‘Prompt’,sans-serif;font-size:13px;font-weight:700;color:var(–orange)}
.food-cal small{font-size:10px;font-weight:400;color:var(–sub)}
.search-box{width:100%;padding:10px 14px;border-radius:12px;border:1.5px solid var(–border);font-family:‘Sarabun’,sans-serif;font-size:13px;background:#fff;margin-bottom:12px;outline:none;transition:border-color .2s}
.search-box:focus{border-color:var(–orange)}

/* SUMMARY PANEL */
.sum-panel{background:#fff;border-radius:22px;padding:22px;box-shadow:var(–shadow);position:sticky;top:72px}
.sum-title{font-family:‘Prompt’,sans-serif;font-size:16px;font-weight:700;margin-bottom:16px}
.cal-display{background:linear-gradient(135deg,var(–dark),#0f3460);border-radius:16px;padding:18px;text-align:center;margin-bottom:14px}
.cal-num{font-family:‘Prompt’,sans-serif;font-size:44px;font-weight:800;color:var(–yellow);line-height:1}
.cal-unit{color:rgba(255,255,255,.5);font-size:12px;margin-top:3px}
.cal-rem{color:rgba(255,255,255,.4);font-size:10px;margin-top:2px}
.gauge{margin:10px 0}
.gauge-lbl{display:flex;justify-content:space-between;font-size:11px;color:var(–sub);margin-bottom:5px}
.gauge-track{height:8px;background:#f0ebe4;border-radius:10px;overflow:hidden}
.gauge-fill{height:100%;border-radius:10px;transition:width .5s cubic-bezier(.4,2,.6,1);background:linear-gradient(90deg,var(–green),var(–yellow),var(–orange),var(–red))}
.macro-row{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:12px}
.macro-box{background:var(–bg);border-radius:11px;padding:9px 6px;text-align:center}
.macro-val{font-family:‘Prompt’,sans-serif;font-size:14px;font-weight:700}
.macro-nm{font-size:10px;color:var(–sub);margin-top:2px}
.sel-list{margin-top:12px;max-height:200px;overflow-y:auto;padding-right:4px}
.sel-list::-webkit-scrollbar{width:3px}
.sel-list::-webkit-scrollbar-track{background:#f0ebe4;border-radius:4px}
.sel-list::-webkit-scrollbar-thumb{background:var(–border);border-radius:4px}
.sel-item{display:flex;align-items:center;gap:7px;padding:7px 0;border-bottom:1px solid var(–border);animation:fadeIn .25s ease}
@keyframes fadeIn{from{opacity:0;transform:translateX(8px)}to{opacity:1;transform:none}}
.sel-emo{font-size:18px;flex-shrink:0}
.sel-nm{flex:1;font-size:11px;font-weight:600;line-height:1.3}
.sel-cal{font-family:‘Prompt’,sans-serif;font-weight:700;font-size:12px;color:var(–orange);white-space:nowrap}
.sel-rm{background:none;border:none;cursor:pointer;color:#ccc;font-size:14px;padding:0 2px;transition:color .15s}
.sel-rm:hover{color:var(–red)}
.empty-st{text-align:center;padding:24px 0;color:var(–sub)}
.empty-st .emo{font-size:32px;margin-bottom:6px}
.empty-st p{font-size:12px;line-height:1.7}
.tip-box{background:linear-gradient(135deg,#f0fff9,#e8f8f2);border:1.5px solid rgba(6,214,160,.3);border-radius:13px;padding:11px 13px;margin-top:12px;font-size:12px;line-height:1.7;color:#2d7a5e}
.tip-box strong{display:block;margin-bottom:2px}
.btn-clear{width:100%;margin-top:10px;padding:10px;border-radius:11px;border:1.5px solid var(–border);background:#fff;cursor:pointer;font-family:‘Sarabun’,sans-serif;font-size:12px;font-weight:600;color:var(–sub);transition:all .2s}
.btn-clear:hover{background:#fff3f3;border-color:var(–red);color:var(–red)}

/* CALC PAGE */
.calc-page{max-width:960px;margin:0 auto;padding:36px 24px}
.calc-hero{border-radius:22px;padding:36px 30px;color:#fff;margin-bottom:20px;position:relative;overflow:hidden}
.calc-hero h2{font-family:‘Prompt’,sans-serif;font-size:26px;font-weight:800;margin-bottom:8px}
.calc-hero p{color:rgba(255,255,255,.65);font-size:14px;line-height:1.7}
.form-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;margin-bottom:20px}
.fg label{display:block;font-size:12px;font-weight:700;color:var(–sub);margin-bottom:5px}
.fg input,.fg select{width:100%;padding:10px 13px;border-radius:11px;border:1.5px solid var(–border);font-family:‘Sarabun’,sans-serif;font-size:13px;background:#fff;outline:none;transition:border-color .2s;color:var(–text)}
.fg input:focus,.fg select:focus{border-color:var(–orange)}

/* RESULT BOXES */
.result-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:14px;margin-bottom:20px}
.res-box{background:#fff;border-radius:18px;padding:22px 18px;box-shadow:var(–shadow);text-align:center;border-top:4px solid var(–orange)}
.res-box.g{border-top-color:var(–green)}.res-box.b{border-top-color:var(–blue)}.res-box.r{border-top-color:var(–red)}.res-box.p{border-top-color:#7209B7}
.res-num{font-family:‘Prompt’,sans-serif;font-size:30px;font-weight:800;color:var(–dark)}
.res-unit{font-size:11px;color:var(–sub);margin-top:2px}
.res-lbl{font-size:13px;font-weight:700;margin-top:7px;color:var(–text)}
.res-desc{font-size:11px;color:var(–sub);margin-top:4px;line-height:1.5}

/* GOAL TABS */
.goal-tabs{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap}
.goal-tab{padding:10px 20px;border-radius:12px;border:2px solid var(–border);background:#fff;cursor:pointer;font-family:‘Sarabun’,sans-serif;font-size:13px;font-weight:700;color:var(–sub);transition:all .2s}
.goal-tab.active{border-color:var(–orange);background:var(–orange);color:#fff}
.goal-tab:hover:not(.active){border-color:var(–orange);color:var(–orange)}

/* BMI */
.bmi-scale{display:flex;border-radius:9px;overflow:hidden;height:28px;margin-bottom:8px}
.bmi-seg{flex:1;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff}
.bmi-ptr-row{position:relative;height:18px;margin-top:4px}
.bmi-ptr{position:absolute;transform:translateX(-50%);font-size:18px;transition:left .5s cubic-bezier(.4,2,.6,1)}
.bmi-lbls{display:flex;justify-content:space-between;font-size:10px;color:var(–sub);margin-top:3px}
.bmi-desc{margin-top:14px;padding:12px;border-radius:12px;font-size:13px;font-weight:600;text-align:center}

/* AGE TABLE */
.age-table{width:100%;border-collapse:collapse;font-size:12px}
.age-table th{background:var(–dark);color:#fff;padding:9px 12px;text-align:left;font-family:‘Prompt’,sans-serif;font-size:11px;font-weight:700;letter-spacing:.5px}
.age-table td{padding:9px 12px;border-bottom:1px solid var(–border)}
.age-table tr:hover td{background:#fef9f5}
.age-table tr.hl td{background:rgba(255,107,53,.06)}
.hl-cell{font-weight:700;color:var(–orange)}

/* MEAL PLAN */
.meal-row{display:flex;gap:11px;margin-bottom:11px;flex-wrap:wrap}
.meal-badge{border-radius:10px;padding:10px 12px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-width:82px;flex-shrink:0}
.meal-badge .mico{font-size:22px}
.meal-badge .mnm{font-family:‘Prompt’,sans-serif;font-size:11px;font-weight:700;margin-top:3px;color:#333}
.meal-badge .mtm{font-size:10px;color:#999}
.meal-body{flex:1;background:var(–bg);border-radius:11px;padding:10px 14px;min-width:200px}
.meal-item{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px dashed var(–border);font-size:12px}
.meal-item:last-child{border:none}
.meal-item-cal{font-family:‘Prompt’,sans-serif;font-weight:700;font-size:12px;color:var(–orange)}
.meal-total{background:rgba(255,107,53,.08);border-radius:9px;padding:8px 12px;display:flex;justify-content:space-between;font-size:13px;font-weight:700;margin-top:7px}
.meal-total-cal{font-family:‘Prompt’,sans-serif;color:var(–orange);font-size:15px}

/* WEEKLY MEAL PLAN TABLE */
.weekly-table{width:100%;border-collapse:collapse;font-size:12px;margin-top:4px}
.weekly-table th{background:var(–dark);color:#fff;padding:10px 8px;font-family:‘Prompt’,sans-serif;font-size:11px;font-weight:700;text-align:center}
.weekly-table td{padding:8px;border:1px solid var(–border);vertical-align:top;min-width:100px}
.weekly-table tr:nth-child(even) td{background:#fafaf8}
.wday-head{background:var(–orange)!important;color:#fff;font-family:‘Prompt’,sans-serif;font-weight:700;font-size:12px;text-align:center}
.meal-cell{font-size:11px;line-height:1.6}
.meal-cell .nm{font-weight:700;color:var(–text)}
.meal-cell .cl{color:var(–orange);font-family:‘Prompt’,sans-serif;font-weight:700;font-size:12px}
.meal-cell .note{color:var(–sub);font-size:10px}

/* EXERCISE */
.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:7px;margin-top:14px}
@media(max-width:550px){.week-grid{grid-template-columns:repeat(4,1fr)}}
.day-card{border-radius:13px;padding:10px 7px;text-align:center;border:2px solid var(–border);cursor:pointer;transition:all .2s}
.day-card:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.12)}
.day-card.rest{background:#fafafa;border-color:#eee}
.day-card.active-day{background:linear-gradient(135deg,#f0fff9,#e0f8f0);border-color:var(–green)}
.day-card.cardio{background:linear-gradient(135deg,#fff3e0,#ffe5cc);border-color:var(–orange)}
.day-card.strength{background:linear-gradient(135deg,#e8f0ff,#dce8ff);border-color:var(–blue)}
.day-nm{font-family:‘Prompt’,sans-serif;font-size:10px;font-weight:700;color:var(–sub);margin-bottom:5px}
.day-ico{font-size:22px;margin-bottom:5px}
.day-ty{font-size:9px;font-weight:700;margin-bottom:3px}
.day-kcal{font-family:‘Prompt’,sans-serif;font-size:11px;font-weight:700;color:var(–orange)}
.ex-row{display:flex;align-items:center;gap:11px;padding:11px;border-radius:11px;background:var(–bg);margin-bottom:8px}
.ex-ico{font-size:26px;flex-shrink:0}
.ex-info{flex:1}
.ex-nm{font-weight:700;font-size:13px;margin-bottom:2px}
.ex-desc{font-size:11px;color:var(–sub)}
.ex-cal-badge{background:var(–orange);color:#fff;border-radius:8px;padding:4px 9px;font-family:‘Prompt’,sans-serif;font-size:11px;font-weight:700;white-space:nowrap}
.burn-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;margin-top:6px}
.burn-card{background:#fff;border-radius:14px;padding:14px;box-shadow:0 2px 10px rgba(0,0,0,.06);text-align:center}
.burn-ico{font-size:30px;margin-bottom:5px}
.burn-nm{font-weight:700;font-size:12px;margin-bottom:3px}
.burn-cal{font-family:‘Prompt’,sans-serif;font-size:20px;font-weight:800;color:var(–orange)}
.burn-unit{font-size:10px;color:var(–sub)}
.burn-note{font-size:10px;color:var(–sub);margin-top:2px}
.level-bar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;padding:14px 18px}
.chip{padding:7px 16px;border-radius:20px;border:1.5px solid var(–border);background:#fff;cursor:pointer;font-family:‘Sarabun’,sans-serif;font-size:12px;font-weight:600;color:var(–sub);transition:all .18s}
.chip.on{background:var(–orange);border-color:var(–orange);color:#fff}

/* CHULA */
.chula-hero{background:linear-gradient(135deg,#8b1a1a,#c0392b,#922b21);border-radius:22px;padding:36px 30px;color:#fff;margin-bottom:20px;position:relative;overflow:hidden}
.chula-hero::after{content:‘🏥’;position:absolute;right:24px;top:50%;transform:translateY(-50%);font-size:72px;opacity:.12}
.chula-hero h2{font-family:‘Prompt’,sans-serif;font-size:26px;font-weight:800;margin-bottom:8px}
.chula-hero p{color:rgba(255,255,255,.65);font-size:14px;line-height:1.7}
.chula-badge{display:inline-flex;align-items:center;gap:5px;background:linear-gradient(135deg,#8b1a1a,#c0392b);color:#fff;border-radius:20px;padding:4px 13px;font-size:11px;font-weight:700;margin-bottom:14px}
.chula-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:12px;margin-bottom:16px}
.chula-card{border-radius:15px;overflow:hidden;box-shadow:0 2px 10px rgba(0,0,0,.07);transition:all .2s;background:#fff}
.chula-card:hover{transform:translateY(-3px);box-shadow:0 8px 22px rgba(0,0,0,.12)}
.chula-img{width:100%;height:100px;object-fit:cover;display:block}
.chula-emo{width:100%;height:100px;display:flex;align-items:center;justify-content:center;font-size:42px}
.chula-info{padding:10px}
.chula-nm{font-weight:700;font-size:12px;margin-bottom:3px}
.chula-cal{font-family:‘Prompt’,sans-serif;font-size:13px;font-weight:700;color:#c0392b}
.chula-cal small{font-size:10px;color:var(–sub);font-weight:400}
.chula-note{font-size:10px;color:var(–sub);margin-top:2px}
.healthy-tag{display:inline-block;background:#e8faf2;color:#2d7a5e;font-size:10px;font-weight:700;padding:2px 7px;border-radius:9px;margin-top:3px}
.meal-guide-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:12px;margin-bottom:16px}
.mg-card{border-radius:14px;padding:16px;border-left-width:4px;border-left-style:solid}
.mg-card .mico{font-size:26px;margin-bottom:7px}
.mg-card .mnm{font-family:‘Prompt’,sans-serif;font-weight:700;font-size:13px;margin-bottom:5px}
.mg-card .mdesc{font-size:12px;color:#666;line-height:1.7}
.tip-warn{border-radius:13px;padding:14px 18px;font-size:12px;line-height:1.9;border-width:1.5px;border-style:solid}
.disease-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px}
.disease-card{background:#fff;border-radius:11px;padding:13px}
.disease-ico{font-size:22px;margin-bottom:5px}
.disease-nm{font-weight:700;font-size:12px;margin-bottom:3px}
