/* ===================== FOOD CALC ===================== */
var selected = {};
var pageBuilt = {};

function buildFoodPage(k) {
  var d = foodData[k];
  var el = document.getElementById('page-' + k);
  var html = '<div class="calc-layout"><div>';
  html += '<div style="margin-bottom:16px"><div style="font-family:Prompt,sans-serif;font-size:20px;font-weight:800;margin-bottom:4px">🍽️ ' + d.name + '</div><div style="color:var(--sub);font-size:12px">เลือกเมนูที่คุณทานในมื้อนี้</div></div>';
  html += '<input class="search-box" type="text" placeholder="🔍 ค้นหาเมนู..." oninput="filterFood(\'' + k + '\',this.value)">';
  for (var cat in d.cats) {
    var foods = d.cats[cat];
    html += '<div class="food-sec-hd" id="hd-' + k + '-' + cat + '">' + cat + '</div>';
    html += '<div class="food-grid" id="fg-' + k + '-' + cat + '">';
    for (var i = 0; i < foods.length; i++) {
      html += buildFoodCard(foods[i], k);
    }
    html += '</div>';
  }
  html += '</div>';
  html += buildSummaryPanel(k);
  html += '</div>';
  el.innerHTML = html;
  updateSummary(k);
}

function buildFoodCard(f, k) {
  var sel = selected[f.id] ? ' sel' : '';
  var imgPart = f.img
    ? '<img class="food-img" src="' + f.img + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\'">' +
      '<div class="food-emo" style="display:none">' + f.emo + '</div>'
    : '<div class="food-emo">' + f.emo + '</div>';
  return '<div class="food-card' + sel + '" id="fc-' + f.id + '" onclick="toggleFood(\'' + f.id + '\',\'' + k + '\')">' +
    imgPart +
    '<div class="food-info"><div class="food-nm">' + f.nm + '</div>' +
    '<div class="food-cal">' + f.cal + ' <small>kcal</small></div></div></div>';
}

function buildSummaryPanel(k) {
  var tdee = window.userTDEE || 2000;
  return '<div class="sum-panel">' +
    '<div class="sum-title">🧮 สรุปแคลอรี่มื้อนี้</div>' +
    '<div class="cal-display">' +
      '<div class="cal-num" id="sp-cal-' + k + '">0</div>' +
      '<div class="cal-unit">แคลอรี่รวม (kcal)</div>' +
      '<div class="cal-rem" id="sp-rem-' + k + '">เป้าหมาย: ' + tdee + ' kcal</div>' +
    '</div>' +
    '<div class="gauge">' +
      '<div class="gauge-lbl"><span>0</span><span id="sp-glbl-' + k + '">เป้า ' + tdee + ' kcal</span></div>' +
      '<div class="gauge-track"><div class="gauge-fill" id="sp-g-' + k + '" style="width:0%"></div></div>' +
    '</div>' +
    '<div class="macro-row">' +
      '<div class="macro-box"><div class="macro-val" style="color:#06D6A0" id="sp-p-' + k + '">0g</div><div class="macro-nm">โปรตีน</div></div>' +
      '<div class="macro-box"><div class="macro-val" style="color:#FFD166" id="sp-c-' + k + '">0g</div><div class="macro-nm">คาร์บ</div></div>' +
      '<div class="macro-box"><div class="macro-val" style="color:#EF233C" id="sp-f-' + k + '">0g</div><div class="macro-nm">ไขมัน</div></div>' +
    '</div>' +
    '<div id="sp-list-' + k + '" class="sel-list">' +
      '<div class="empty-st"><div class="emo">🍽️</div><p>ยังไม่ได้เลือกเมนู<br>คลิกที่รูปอาหารเพื่อเพิ่ม</p></div>' +
    '</div>' +
    '<button class="btn-clear" onclick="clearAll(\'' + k + '\')">🗑️ ล้างทั้งหมด</button>' +
    '<div class="tip-box" id="sp-tip-' + k + '"><strong>💡 เคล็ดลับ</strong>เลือกเมนูแล้วดูแคลอรี่รวม หรือไปคำนวณ TDEE ก่อนเพื่อตั้งเป้าหมาย</div>' +
    '</div>';
}

function toggleFood(id, k) {
  selected[id] = !selected[id];
  var el = document.getElementById('fc-' + id);
  if (el) el.className = 'food-card' + (selected[id] ? ' sel' : '');
  updateSummary(k);
}

function updateSummary(k) {
  var d = foodData[k];
  var total = 0, prot = 0, carb = 0, fat = 0, items = [];
  for (var cat in d.cats) {
    var foods = d.cats[cat];
    for (var i = 0; i < foods.length; i++) {
      var f = foods[i];
      if (selected[f.id]) {
        total += f.cal; prot += f.p; carb += f.c; fat += f.f;
        items.push(f);
      }
    }
  }
  var calEl = document.getElementById('sp-cal-' + k);
  if (!calEl) return;
  var tdee = window.userTDEE || 2000;
  calEl.textContent = total;
  var rem = tdee - total;
  document.getElementById('sp-rem-' + k).textContent = rem >= 0 ? 'เหลือ: ' + rem + ' kcal' : 'เกินเป้า: ' + Math.abs(rem) + ' kcal';
  document.getElementById('sp-g-' + k).style.width = Math.min(100, (total / tdee) * 100) + '%';
  document.getElementById('sp-p-' + k).textContent = prot + 'g';
  document.getElementById('sp-c-' + k).textContent = carb + 'g';
  document.getElementById('sp-f-' + k).textContent = fat + 'g';
  var listEl = document.getElementById('sp-list-' + k);
  if (items.length === 0) {
    listEl.innerHTML = '<div class="empty-st"><div class="emo">🍽️</div><p>ยังไม่ได้เลือกเมนู<br>คลิกที่รูปอาหารเพื่อเพิ่ม</p></div>';
  } else {
    var rows = '';
    for (var j = 0; j < items.length; j++) {
      var fi = items[j];
      rows += '<div class="sel-item">' +
        '<div class="sel-emo">' + fi.emo + '</div>' +
        '<div class="sel-nm">' + fi.nm + '</div>' +
        '<div class="sel-cal">' + fi.cal + '</div>' +
        '<button class="sel-rm" onclick="toggleFood(\'' + fi.id + '\',\'' + k + '\')">✕</button>' +
        '</div>';
    }
    listEl.innerHTML = rows;
  }
  var tipEl = document.getElementById('sp-tip-' + k);
  if (!tipEl) return;
  if (total === 0) tipEl.innerHTML = '<strong>💡 เคล็ดลับ</strong>เลือกเมนูแล้วดูแคลอรี่รวม';
  else if (total < 400) tipEl.innerHTML = '<strong>😊 น้อยมาก!</strong>ลองเพิ่มโปรตีนเพื่อให้อิ่มนานขึ้น';
  else if (total < tdee * 0.35) tipEl.innerHTML = '<strong>✅ ดีมาก!</strong>แคลอรี่มื้อนี้อยู่ในระดับดี';
  else if (total < tdee * 0.5) tipEl.innerHTML = '<strong>⚠️ ค่อนข้างมาก</strong>ระวังเครื่องดื่มหวาน';
  else tipEl.innerHTML = '<strong>🔥 เกินครึ่งเป้าแล้ว!</strong>ควรออกกำลังกายเพิ่มวันนี้';
}

function clearAll(k) {
  var d = foodData[k];
  for (var cat in d.cats) {
    var foods = d.cats[cat];
    for (var i = 0; i < foods.length; i++) {
      selected[foods[i].id] = false;
      var el = document.getElementById('fc-' + foods[i].id);
      if (el) el.className = 'food-card';
    }
  }
  updateSummary(k);
}

function filterFood(k, q) {
  var d = foodData[k]; q = q.toLowerCase().trim();
  for (var cat in d.cats) {
    var foods = d.cats[cat];
    var any = false;
    for (var i = 0; i < foods.length; i++) {
      var el = document.getElementById('fc-' + foods[i].id);
      if (!el) continue;
      var vis = !q || foods[i].nm.toLowerCase().indexOf(q) >= 0;
      el.style.display = vis ? '' : 'none';
      if (vis) any = true;
    }
    var hdEl = document.getElementById('hd-' + k + '-' + cat);
    var fgEl = document.getElementById('fg-' + k + '-' + cat);
    if (hdEl) hdEl.style.display = any ? '' : 'none';
    if (fgEl) fgEl.style.display = any ? '' : 'none';
  }
}

/* ===================== NAVIGATION ===================== */
var pageMap = {home:0,res1:1,res2:2,res3:3,calctdee:4,exercise:5,chula:6,about:7};

function showPage(k) {
  var pages = document.querySelectorAll('.page');
  for (var i = 0; i < pages.length; i++) pages[i].classList.remove('active');
  var navTabs = document.querySelectorAll('.nav-tab');
  for (var i = 0; i < navTabs.length; i++) navTabs[i].classList.remove('active');
  var bnavBtns = document.querySelectorAll('.bnav-btn');
  for (var i = 0; i < bnavBtns.length; i++) bnavBtns[i].classList.remove('active');
  var pg = document.getElementById('page-' + k);
  if (pg) pg.classList.add('active');
  var idx = pageMap[k];
  if (navTabs[idx]) navTabs[idx].classList.add('active');
  if (bnavBtns[idx]) bnavBtns[idx].classList.add('active');
  if ((k === 'res1' || k === 'res2' || k === 'res3') && !pageBuilt[k]) {
    buildFoodPage(k); pageBuilt[k] = true;
  }
  window.scrollTo({top:0,behavior:'smooth'});
}

/* ===================== TDEE / BMR ===================== */
var userGoal = 'maintain';

function setGoal(g, btn) {
  userGoal = g;
  var tabs = document.querySelectorAll('.goal-tab');
  for (var i = 0; i < tabs.length; i++) tabs[i].classList.remove('active');
  btn.classList.add('active');
  calcTDEE();
}

function calcTDEE() {
  var g = document.getElementById('td-gender').value;
  var age = parseFloat(document.getElementById('td-age').value) || 22;
  var w = parseFloat(document.getElementById('td-weight').value) || 60;
  var h = parseFloat(document.getElementById('td-height').value) || 165;
  var act = parseFloat(document.getElementById('td-activity').value) || 1.55;
  var bmr = g === 'male' ? 10*w + 6.25*h - 5*age + 5 : 10*w + 6.25*h - 5*age - 161;
  var tdee = Math.round(bmr * act);
  var goalCal = userGoal === 'lose' ? tdee - 500 : userGoal === 'gain' ? tdee + 300 : tdee;
  window.userTDEE = goalCal;
  window.userWeight = w;

  /* Result boxes */
  var goalLabel, goalColor, goalDesc;
  if (userGoal === 'lose') {
    goalLabel = '🔻 เป้าลดน้ำหนัก'; goalColor = 'b';
    goalDesc = 'ลด 500 kcal จาก TDEE — ลดได้ ~0.5 กก./สัปดาห์';
  } else if (userGoal === 'gain') {
    goalLabel = '🔺 เป้าเพิ่มน้ำหนัก'; goalColor = 'r';
    goalDesc = 'เพิ่ม 300 kcal จาก TDEE — เพิ่มได้ ~0.3 กก./สัปดาห์';
  } else {
    goalLabel = '⚖️ เป้าคงน้ำหนัก'; goalColor = 'g';
    goalDesc = 'รับพลังงานเท่ากับที่ใช้ — น้ำหนักคงที่';
  }

  var rg = document.getElementById('result-grid');
  rg.innerHTML =
    '<div class="res-box"><div class="res-num">' + Math.round(bmr).toLocaleString() + '</div><div class="res-unit">kcal/วัน</div><div class="res-lbl">🔥 BMR (เผาผลาญพื้นฐาน)</div><div class="res-desc">พลังงานขั้นต่ำที่ร่างกายต้องการขณะพัก</div></div>' +
    '<div class="res-box g"><div class="res-num">' + tdee.toLocaleString() + '</div><div class="res-unit">kcal/วัน</div><div class="res-lbl">✅ TDEE (พลังงานใช้จริง/วัน)</div><div class="res-desc">BMR x ระดับกิจกรรม</div></div>' +
    '<div class="res-box ' + goalColor + '"><div class="res-num" style="font-size:26px">' + goalCal.toLocaleString() + '</div><div class="res-unit">kcal/วัน</div><div class="res-lbl">' + goalLabel + '</div><div class="res-desc">' + goalDesc + '</div></div>' +
    '<div class="res-box p"><div class="res-num" style="font-size:24px">' + Math.round(w * 1.4) + 'g</div><div class="res-unit">โปรตีน/วัน</div><div class="res-lbl">💪 โปรตีนที่แนะนำ</div><div class="res-desc">1.4 กรัม × น้ำหนักตัว</div></div>';

  /* BMI */
  var bmi = w / ((h/100) * (h/100));
  var bmiR = Math.round(bmi * 10) / 10;
  var pct = Math.min(100, Math.max(0, (bmi - 16) / (40 - 16) * 100));
  document.getElementById('bmi-ptr').style.left = pct + '%';
  var descEl = document.getElementById('bmi-desc');
  if (bmi < 18.5) { descEl.style.background = '#e8f4ff'; descEl.style.color = '#1a5276'; descEl.innerHTML = 'BMI: <strong>' + bmiR + '</strong> — ผอมเกินเกณฑ์ ควรเพิ่มน้ำหนัก'; }
  else if (bmi < 23) { descEl.style.background = '#e8faf2'; descEl.style.color = '#2d7a5e'; descEl.innerHTML = 'BMI: <strong>' + bmiR + '</strong> — ✅ น้ำหนักปกติ สุขภาพดีมาก'; }
  else if (bmi < 25) { descEl.style.background = '#fef9e7'; descEl.style.color = '#7d6608'; descEl.innerHTML = 'BMI: <strong>' + bmiR + '</strong> — ⚠️ น้ำหนักเกินเล็กน้อย'; }
  else if (bmi < 30) { descEl.style.background = '#fef5ec'; descEl.style.color = '#935116'; descEl.innerHTML = 'BMI: <strong>' + bmiR + '</strong> — ⚠️ น้ำหนักเกิน ควรลดน้ำหนัก'; }
  else { descEl.style.background = '#fdedec'; descEl.style.color = '#922b21'; descEl.innerHTML = 'BMI: <strong>' + bmiR + '</strong> — 🔴 อ้วน ควรปรึกษาแพทย์'; }

  /* Age table highlight */
  var ageTbody = document.getElementById('age-tbody');
  if (!ageTbody.innerHTML) buildAgeTable();
  var rows = ageTbody.querySelectorAll('tr');
  for (var i = 0; i < rows.length; i++) rows[i].classList.remove('hl');
  var ageRanges = [
    {min:2,max:3,row:0},{min:4,max:8,row:1},{min:9,max:13,row:2},
    {min:14,max:18,row:3},{min:19,max:30,row:4},{min:31,max:50,row:5},
    {min:51,max:65,row:6},{min:66,max:80,row:7},{min:81,max:120,row:8}
  ];
  for (var i = 0; i < ageRanges.length; i++) {
    if (age >= ageRanges[i].min && age <= ageRanges[i].max) {
      if (rows[ageRanges[i].row]) rows[ageRanges[i].row].classList.add('hl');
    }
  }

  renderMealPlan(goalCal, w);
  renderWeeklyPlan(goalCal);
  var ewEl = document.getElementById('ex-weight');
  if (ewEl) ewEl.textContent = w;
  renderWeekGrid();
}

