function renderWeekGrid() {
  var plan = exPlans[currentLevel];
  var w = parseFloat(document.getElementById('td-weight') ? document.getElementById('td-weight').value : 60) || 60;
  var wgEl = document.getElementById('week-grid');
  if (!wgEl) return;
  var html = '';
  for (var i = 0; i < plan.days.length; i++) {
    var day = plan.days[i];
    var burnAdj = Math.round(day.cb * (w / 60));
    var typeColor = day.col === 'rest' ? '#aaa' : day.col === 'cardio' ? 'var(--orange)' : day.col === 'strength' ? 'var(--blue)' : 'var(--green)';
    var typeThai = day.ty === 'rest' ? 'พักผ่อน' : day.ty === 'cardio' ? 'Cardio' : day.ty === 'strength' ? 'Strength' : 'Recovery';
    var calPart = day.cb ? '<div class="day-kcal">' + burnAdj + ' kcal</div>' : '<div style="font-size:9px;color:#ccc">พักผ่อน</div>';
    html += '<div class="day-card ' + day.col + '" onclick="showExDetail(' + i + ')">' +
      '<div class="day-nm">' + day.d + '</div>' +
      '<div class="day-ico">' + day.ico + '</div>' +
      '<div class="day-ty" style="color:' + typeColor + '">' + typeThai + '</div>' +
      calPart + '</div>';
  }
  wgEl.innerHTML = html;
}

function showExDetail(idx) {
  var plan = exPlans[currentLevel];
  var day = plan.days[idx];
  var w = parseFloat(document.getElementById('td-weight') ? document.getElementById('td-weight').value : 60) || 60;
  var sec = document.getElementById('ex-detail-card');
  sec.style.display = 'block';
  document.getElementById('ex-detail-title').textContent = day.ico + ' ' + day.lbl;
  document.getElementById('ex-detail-sub').textContent = day.cb ?
    'เผาผลาญประมาณ ' + Math.round(day.cb * (w / 60)) + ' kcal (น้ำหนัก ' + w + ' กก.)' :
    'วันพักผ่อน ให้ร่างกายซ่อมแซมและฟื้นตัว';
  var exList = plan.exs[day.ty] || [];
  var html = '';
  if (exList.length === 0) {
    html = '<div style="text-align:center;padding:20px;color:var(--sub)">🧘 วันนี้พักผ่อน ยืดเส้นเบาๆ นอนหลับให้เพียงพอ</div>';
  } else {
    for (var i = 0; i < exList.length; i++) {
      var ex = exList[i];
      html += '<div class="ex-row"><div class="ex-ico">' + ex.ico + '</div>' +
        '<div class="ex-info"><div class="ex-nm">' + ex.nm + '</div><div class="ex-desc">' + ex.desc + '</div></div>' +
        (ex.c ? '<div class="ex-cal-badge">' + ex.c + '</div>' : '') + '</div>';
    }
  }
  document.getElementById('ex-detail-body').innerHTML = html;
  sec.scrollIntoView({behavior:'smooth', block:'start'});
}

function setLevel(btn, level) {
  currentLevel = level;
  var chips = document.querySelectorAll('.chip');
  for (var i = 0; i < chips.length; i++) chips[i].classList.remove('on');
  btn.classList.add('on');
  renderWeekGrid();
  document.getElementById('ex-detail-card').style.display = 'none';
}

